# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string. Matches docker-compose defaults.
DATABASE_URL="postgresql://plc_user:plc_password@localhost:5432/personal_language_coach"

# ── Auth ──────────────────────────────────────────────────────
# Random secret used to sign JWT tokens. Use a long random string in production.
JWT_SECRET="change-me-in-production"

# ── External APIs ─────────────────────────────────────────────
# DeepL API key — used to generate reference translations.
# Free tier available at https://www.deepl.com/pro-api
DEEPL_API_KEY="your-deepl-api-key"

# Anthropic API key — used to generate structured feedback via Claude.
# https://console.anthropic.com
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ── Server ────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:4200"
PORT=3000
